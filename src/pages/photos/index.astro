---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPhotos = await getCollection("photos");
allPhotos.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const albums = [
    { id: "all", label: "all" },
    { id: "film", label: "film" },
    { id: "tmb", label: "tmb" },
    { id: "japan", label: "japan" },
    { id: "life", label: "life" },
    { id: "alberta", label: "alberta" },
];
---

<BaseLayout pageTitle="Photos">
    <div class="filter-bar">
        {
            albums.map((album) => (
                <button
                    class="filter-btn"
                    data-album={album.id}
                    aria-pressed={album.id === "all" ? "true" : "false"}
                >
                    {album.label}
                </button>
            ))
        }
    </div>

    <div class="photo-grid" id="photo-grid">
        <div class="col" id="col-left"></div>
        <div class="col" id="col-right"></div>
    </div>

    <!-- pool: rendered but invisible so images can load and be measured -->
    <div id="photo-pool">
        {
            allPhotos.map((photo) => (
                <figure class="photo-item" data-tags={photo.data.tags.join(" ")}>
                    <div class="photo-wrap">
                        <img
                            src={photo.data.src}
                            alt={photo.data.alt}
                            loading="eager"
                        />
                        {photo.data.hover_info && (
                            <div class="photo-overlay">{photo.data.hover_info}</div>
                        )}
                    </div>
                    {photo.data.caption && (
                        <figcaption>{photo.data.caption}</figcaption>
                    )}
                </figure>
            ))
        }
    </div>
</BaseLayout>

<style>
    .filter-bar {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
    }

    .filter-btn {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        font-size: 0.875rem;
        color: var(--text-secondary);
        font-family: inherit;
    }

    .filter-btn:hover {
        color: var(--text);
    }

    .filter-btn[aria-pressed="true"] {
        color: var(--text);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
    }

    .photo-grid {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        width: 100vw;
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        padding: 0 1.5rem;
    }

    .col {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .photo-wrap {
        position: relative;
    }

    .photo-item img {
        width: 100%;
        height: auto;
        display: block;
        margin: 0;
        border-radius: 0;
    }

    .photo-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: flex-end;
        padding: 0.5rem;
        font-size: 0.75rem;
        color: #fff;
        background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 50%);
        opacity: 0;
        transition: opacity 0.15s ease;
    }

    .photo-wrap:hover .photo-overlay {
        opacity: 1;
    }

    figcaption {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-top: 0.25rem;
        padding: 0 0.125rem;
    }

    #photo-pool {
        position: absolute;
        opacity: 0;
        pointer-events: none;
        width: 1px;
        overflow: hidden;
    }

    @media (max-width: 480px) {
        .photo-grid {
            flex-direction: column;
        }
    }
</style>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const pool = Array.from(document.querySelectorAll<HTMLElement>("#photo-pool .photo-item"));
    const colLeft = document.getElementById("col-left")!;
    const colRight = document.getElementById("col-right")!;

    async function getHeights(photos: HTMLElement[]): Promise<number[]> {
        const colWidth = colLeft.getBoundingClientRect().width;
        const gap = 16; // 1rem gap between photos
        const imgs = photos.map((p) => p.querySelector("img")!);
        await Promise.all(imgs.map((img) => img.decode().catch(() => {})));
        return imgs.map((img) =>
            img.naturalWidth > 0
                ? (img.naturalHeight / img.naturalWidth) * colWidth + gap
                : 300,
        );
    }

    async function distribute(album: string) {
        const visible = pool.filter((item) => {
            const tags = item.dataset.tags?.split(" ") ?? [];
            return album === "all" || tags.includes(album);
        });

        const heights = await getHeights(visible);

        colLeft.innerHTML = "";
        colRight.innerHTML = "";

        let leftH = 0;
        let rightH = 0;
        visible.forEach((item, i) => {
            if (leftH <= rightH) {
                colLeft.appendChild(item);
                leftH += heights[i];
            } else {
                colRight.appendChild(item);
                rightH += heights[i];
            }
        });
    }

    async function setFilter(album: string) {
        buttons.forEach((btn) => {
            btn.setAttribute(
                "aria-pressed",
                btn.dataset.album === album ? "true" : "false",
            );
        });
        await distribute(album);
        history.replaceState(
            null,
            "",
            album === "all" ? "/photos/" : `/photos/#${album}`,
        );
    }

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => setFilter(btn.dataset.album!));
    });

    const hash = location.hash.slice(1);
    const validTags = ["film", "tmb", "japan", "life", "alberta"];
    setFilter(hash && validTags.includes(hash) ? hash : "all");
</script>
